---
const experiences = [
  {
    imagesrc: "/images/hoppscotch.jpg",
    title: "Hoppscotch",
    beginDate: "01/01/2023",
    description: "Open Source contributor.",
    contributions: [
      "Contributed improvements to the codebase.",
      "Collaborated through pull requests and code reviews.",
      "Worked with TypeScript and modern frontend technologies.",
      " Participated in issue discussions and bug fixes.",
    ],
  },
  {
    imagesrc: "/images/react.png",
    title: "React js",
    beginDate: "01/02/2025",
    description: "Open Source contributor.",
    contributions: [
      "Contributed improvements to the codebase.",
      "Collaborated through pull requests and code reviews.",
      "Worked with TypeScript and modern frontend technologies.",
      "Participated in issue discussions and bug fixes.",
    ],
  },
];
---

<section id="experiencia" class="scroll-mt-24 bg-[#171c28] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
  <div class="max-w-6xl mx-auto order-1 lg:order-2">
    <h2
      class="mb-8 text-[clamp(2rem,8vw,3.5rem)] font-Montserrat font-medium leading-none text-white text-center"
    >
      Open Source Contributions
    </h2>
    <div class="relative mx-auto max-w-4xl pl-4 sm:pl-8">
      <div class="absolute bottom-0 top-0 left-0 w-0.5 bg-slate-600 sm:left-2"></div>
      {
        experiences.map((exp) => (
          <div class="relative mb-10 sm:mb-12">
            <div class="absolute -left-[0.7rem] top-2 z-10 h-3 w-3 rounded-full border-[3px] border-bg-secondary sm:-left-[1.75rem]" />
            <div class="rounded-xl border border-slate-800 bg-[#1b2233] p-5 shadow-xl transition-all duration-300 hover:border-slate-700 hover:shadow-slate-900 sm:p-8">
              <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-start gap-4">
                  <img
                    src={exp.imagesrc}
                    alt={exp.title}
                    class="h-12 w-12 rounded-lg object-cover"
                  />

                  <div>
                    <h3 class="text-xl font-semibold text-white">
                      {exp.title}
                    </h3>

                    <p class="text-sm text-slate-400 font-Montserrat">
                      Open Source Contributor
                    </p>
                  </div>
                </div>

                <span class="text-sm whitespace-nowrap text-slate-500 font-Montserrat">
                  {exp.beginDate} - Present
                </span>
              </div>

              <p class="mb-6 text-sm leading-relaxed text-slate-300 sm:text-base">
                {exp.description}
              </p>

              <ul class="space-y-3">
                {exp.contributions.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-2 h-2 w-2 rounded-full bg-purple-500 shrink-0" />

                    <span class="text-sm leading-relaxed text-slate-400 sm:text-base">
                      {item}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
