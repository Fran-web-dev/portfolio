---
const experiences = [
  {
    title: "Frontend Developer",
    company: "Personal Projects",
    period: "2020 - 2026",
    description:
      "Development of modern, responsive user interfaces. Implementation of reusable components and optimization of the user experience.",
    technologies: [
      "React",
      "TypeScript",
      "JavaScript",
      "CSS",
      "Tailwindcss",
      "Nextjs",
    ],
  },
];
---

<section id="experiencia" class="py-24 px-8 bg-bg-secondary">
  <div class="max-w-7xl mx-auto">
    <h2
      class="text-[clamp(2rem,5vw,3.5rem)] font-bold mb-12 text-center bg-gradient-to-b from-white to-white/70 bg-clip-text text-transparent"
    >
      Experience
    </h2>
    <div class="max-w-4xl mx-auto relative pl-8">
      <div class="absolute left-2 top-0 bottom-0 w-0.5 bg-border"></div>
      {
        experiences.map((exp) => (
          <div class="relative mb-12">
            <div class="absolute -left-[1.75rem] top-2 w-3 h-3 rounded-full bg-accent border-[3px] border-bg-secondary z-10" />
            <div class="bg-card-bg border border-border rounded-xl p-8 transition-all duration-300 hover:border-accent hover:translate-x-1">
              <div class="flex justify-between items-start mb-2 flex-wrap gap-4">
                <h3 class="text-2xl font-semibold text-text-primary">
                  {exp.title}
                </h3>
                <span class="text-sm text-text-secondary whitespace-nowrap">
                  {exp.period}
                </span>
              </div>
              <p class="text-base text-accent mb-4 font-medium">
                {exp.company}
              </p>
              <p class="text-base leading-relaxed text-text-secondary mb-6">
                {exp.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {exp.technologies.map((tech) => (
                  <span class="bg-accent/10 text-accent px-3.5 py-1.5 rounded-md text-sm border border-accent/20">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #experiencia .max-w-4xl {
      padding-left: 1.5rem;
    }

    #experiencia .absolute.-left-\[1\.75rem\] {
      left: -1.25rem;
    }

    #experiencia .bg-card-bg {
      padding: 1.5rem;
    }

    #experiencia .flex.justify-between {
      flex-direction: column;
    }
  }
</style>
