---
const emailjsServiceId = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID ?? "";
const emailjsTemplateId = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID ?? "";
const emailjsPublicKey = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY ?? "";
---

<section
  id="contacto"
  class="scroll-mt-24 bg-[#171c28] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24"
>
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 text-center">
      <h2 class="text-[clamp(2rem,8vw,3.5rem)] font-semibold font-Montserrat">
        Contact
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-slate-300 sm:text-base lg:text-lg"
      >
        If you are a recruiter or hiring manager, send me a message and I will
        get back to you as soon as possible.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1.1fr,0.9fr]">
      <div
        class="rounded-xl border border-slate-800 bg-[#1b2233] p-5 shadow-xl sm:p-8"
      >
        <div class="mb-6">
          <p class="text-sm uppercase tracking-[0.35em] text-violet-300">
            For recruiters
          </p>
          <h3 class="mt-3 text-xl font-semibold text-white sm:text-2xl">
            Let&apos;s talk about opportunities and how I can contribute to your
            team
          </h3>
        </div>

        <form
          id="contact-form"
          class="space-y-5"
          data-service-id={emailjsServiceId}
          data-template-id={emailjsTemplateId}
          data-public-key={emailjsPublicKey}
        >
          <div>
            <label for="name" class="mb-2 block text-sm text-slate-300">
              Name
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              class="w-full rounded-lg border border-slate-700 bg-[#101521] px-4 py-3 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-violet-400/70 focus:shadow-[0_0_0_1px_rgba(168,85,247,0.15)]"
            />
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm text-slate-300">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="recruiter@company.com"
              class="w-full rounded-lg border border-slate-700 bg-[#101521] px-4 py-3 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-violet-400/70 focus:shadow-[0_0_0_1px_rgba(168,85,247,0.15)]"
            />
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm text-slate-300">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="7"
              placeholder="Tell me about the role, company and the opportunity..."
              class="w-full resize-none rounded-lg border border-slate-700 bg-[#101521] px-4 py-3 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-violet-400/70 focus:shadow-[0_0_0_1px_rgba(168,85,247,0.15)]"
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-lg bg-[rgb(85,25,139)] px-8 py-3 font-semibold text-white transition-all duration-300 hover:-translate-y-1 hover:bg-white hover:text-[rgb(85,25,139)] hover:shadow-xl sm:w-auto"
          >
            Send
          </button>

          <p id="contact-status" class="hidden text-sm text-slate-300"></p>
        </form>
      </div>

      <aside
        class="rounded-xl border border-slate-800 bg-[#1b2233] p-5 shadow-xl sm:p-8"
      >
        <div class="mb-6">
          <p class="text-sm uppercase tracking-[0.35em] text-violet-300">
            Networks
          </p>
          <h3 class="mt-3 text-xl font-semibold text-white sm:text-2xl">
            Other contact options
          </h3>
        </div>

        <div class="space-y-4">
          <a
            href="https://github.com/Fran-web-dev"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-xl border border-slate-800 bg-[#101521] px-4 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-slate-700 hover:shadow-[0_12px_30px_rgba(0,0,0,0.28)]"
          >
            <span
              class="flex h-12 w-12 items-center justify-center rounded-full bg-[#333333]"
            >
              <svg class="h-5 w-5 text-white" aria-hidden="true">
                <use href="/icons.svg#github-icon"></use>
              </svg>
            </span>
            <div>
              <p class="font-medium text-white">GitHub</p>
              <p class="text-sm text-slate-400">Fran-web-dev</p>
            </div>
          </a>

          <a
            href="https://discord.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-xl border border-slate-800 bg-[#101521] px-4 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-[#5865F2]/40 hover:shadow-[0_12px_30px_rgba(0,0,0,0.28)]"
          >
            <span
              class="flex h-12 w-12 items-center justify-center rounded-full bg-[#5865F2]/15"
            >
              <svg class="h-5 w-5 text-[#5865F2]" aria-hidden="true">
                <use href="/icons.svg#discord-icon"></use>
              </svg>
            </span>
            <div>
              <p class="font-medium text-[#b9c0ff]">Discord</p>
              <p class="text-sm text-slate-400">Send me a DM</p>
            </div>
          </a>

          <a
            href="mailto:franklinevillanueva4@gmail.com"
            class="flex items-center gap-4 rounded-xl border border-slate-800 bg-[#101521] px-4 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-slate-700 hover:shadow-[0_12px_30px_rgba(0,0,0,0.28)]"
          >
            <span
              class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-full bg-white"
            >
              <img
                src="/images/gmail.png"
                alt="Gmail"
                class="h-7 w-7 object-contain"
              />
            </span>
            <div>
              <p class="font-medium text-[#f2b8b5]">Email</p>
              <p class="text-sm text-slate-400">
                franklinevillanueva4@gmail.com
              </p>
            </div>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("contact-form");
  const statusMessage = document.getElementById("contact-status");
  const EMAILJS_ENDPOINT = "https://api.emailjs.com/api/v1.0/email/send";

  const showStatus = (message, isError = false) => {
    if (!statusMessage) return;
    statusMessage.classList.remove("hidden");
    statusMessage.textContent = message;
    statusMessage.style.color = isError ? "#fca5a5" : "#d1d5db";
  };

  const serviceId = form?.dataset.serviceId || "";
  const templateId = form?.dataset.templateId || "";
  const publicKey = form?.dataset.publicKey || "";

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const target = event.currentTarget;
    if (!(target instanceof HTMLFormElement)) return;

    const formData = new FormData(target);
    const name = String(formData.get("name") ?? "").trim();
    const email = String(formData.get("email") ?? "").trim();
    const message = String(formData.get("message") ?? "").trim();

    if (!serviceId || !templateId || !publicKey) {
      showStatus("EmailJS is not configured yet. Check your env values.", true);
      return;
    }

    showStatus("Sending your message...");

    try {
      const response = await fetch(EMAILJS_ENDPOINT, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          service_id: serviceId,
          template_id: templateId,
          user_id: publicKey,
          template_params: {
            from_name: name,
            reply_to: email,
            from_email: email,
            message,
          },
        }),
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(errorText || "Unable to send the message.");
      }

      target.reset();
      showStatus("Message sent successfully. I'll get back to you soon.");
    } catch (error) {
      showStatus(
        error instanceof Error
          ? error.message
          : "Unable to send the message right now.",
        true,
      );
    }
  });
</script>
