        >
          <span class="text-2xl">💼</span>
          <span>LinkedIn</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #contacto a {
      padding: 1rem 1.5rem;
      font-size: 1rem;
    }
