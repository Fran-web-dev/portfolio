<section id="contacto" class="py-24 px-8 bg-[#171c28]">
  <div class="max-w-7xl mx-auto">
    <h2
      class="text-[clamp(2rem,5vw,3.5rem)] font-bold mb-12 text-center bg-gradient-to-b from-white to-white/70 bg-clip-text text-transparent"
    >
      Contact
    </h2>
    <div class="max-w-2xl mx-auto text-center">
      <div class="flex flex-col gap-6">
        <a
          href="franklinevillanueva4@gmail.com"
          class="flex items-center justify-center gap-4 px-8 py-5 bg-card-bg border border-border rounded-xl text-lg text-text no-underline transition-all duration-300 hover:border-accent hover:bg-accent/10 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(0,112,243,0.2)]"
        >
          <span class="text-2xl">✉️</span>
          <span>franklinevillanueva4@gmail.com</span>
        </a>
        <a
