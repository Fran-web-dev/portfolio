<section id="sobre-mi" class="py-24 px-8 bg-[#171c28]">
  <div class="max-w-7xl mx-auto">
    <div class="grid gap-12 md:grid-cols-[1.1fr,0.9fr] items-center">
      <div>
        <h2
          class="text-[clamp(1rem,5vw,3.5rem)] font-semibold font-Montserrat mb-8 bg-gradient-to-b text-white"
        >
          Hi, I'm Franklin
        </h2>
        <div
          class="text-2xl font-Montserrat font-normal leading-relaxed text space-y-6"
        >
          <p>
            Building fast, accessible and modern web applications with React,
            TypeScript, Astro and Node.js. Focused on performance, clean UI
            design and exceptional user experiences.
          </p>

          <p>
            Focused on performance, clean UI design and exceptional user
            experiences.
          </p>
          <div class="flex items-center gap-4 my-4">
            <div class="flex items-center gap-4 my-6">
              <a
                href="https://github.com/Fran-web-dev"
                class="w-12 h-12 rounded-full bg-[#333333] flex items-center justify-center hover:scale-110 transition-transform"
              >
                <img
                  src="/images/github.png"
                  class="w-5 h-5 object-contain"
                />
              </a>

              <a
                href="mailto:franklinevillanueva4@gmail.com"
                class="w-12 h-12 rounded-full bg-[#EA4335] flex items-center justify-center hover:scale-110 transition-transform"
              >
                <img
                  src="/images/gmail.png"
                  alt="Gmail"
                  class="w-5 h-5 object-contain"
                />
              </a>
            </div>
          </div>
          <div class="flex flex-wrap gap-6">
            <a
              href="#contacto"
              class="px-9 py-3 rounded-lg bg-[rgb(85,25,139)] text-white font-semibold text-base border border-transparent transition-all duration-300 ease-out hover:-translate-y-1 hover:bg-white hover:text-[rgb(85,25,139)] hover:border-[rgb(85,25,139)] hover:shadow-xl"
            >
              CONTACT ME
            </a>
            <a
              href="/downloads/Franklin_Villanueva_Resume.pdf"
              download="Franklin_Villanueva_CV.pdf"
              class="px-9 py-3 rounded-lg bg-[rgb(85,25,139)] text-white font-semibold text-base border border-transparent transition-all duration-300 ease-out hover:-translate-y-1 hover:bg-white hover:text-[rgb(85,25,139)] hover:border-[rgb(85,25,139)] hover:shadow-xl"
            >
              DOWNLOAD MY RESUME
            </a>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="absolute inset-0 blur-[120px] opacity-20"></div>
        <div
          class="relative rounded-[32px] overflow-hidden border border-white/10 shadow-[0_40px_120px_rgba(0,0,0,0.45)]"
        >
          <img
            src="/images/profile.png"
            alt="Franklin working in a futuristic digital environment"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div
            class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/90 via-black/40 to-transparent"
          >
            <p class="text-sm uppercase tracking-[0.5em] text-white/60 mb-2">
              Presence
            </p>
            <p class="text-2xl font-semibold text-white">LatAm | Global Remote</p>
          </div>
        </div>
      </div>
    </div>
