---
import TextType from "./TextType";
---

<section
  id="sobre-mi"
  class="bg-[#171c28] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid items-center gap-10 lg:grid-cols-[1.1fr,0.9fr] lg:gap-12">
      <div class="order-2 lg:order-1">
        <TextType
          client:load
          text={["Frontend "]}
          loop={false}
          typingSpeed={145}
          pauseDuration={1000}
          showCursor={false}
          deletingSpeed={62}
          cursorBlinkDuration={1.15}
          className="text-[clamp(2.2rem,8vw,3.5rem)] font-semibold font-Montserrat"
        />
        <TextType
          client:load
          text={["Developer"]}
          loop={true}
          typingSpeed={145}
          pauseDuration={3300}
          deletingSpeed={62}
          cursorBlinkDuration={1.15}
          className="mb-6 text-[clamp(2.2rem,8vw,3.5rem)] font-semibold font-Montserrat bg-gradient-to-b from-[#FFFFFF] via-[#D8B4FE] to-[#55198B] bg-clip-text text-transparent sm:mb-8"
        />
        <div
          class="space-y-5 text-base font-Montserrat font-normal leading-relaxed text-slate-200 sm:text-lg lg:text-2xl"
        >
          <p>React • TypeScript • Astro</p>
          <p>
            Building fast, accessible and modern web applications with React,
            TypeScript, Astro and Node.js. Focused on performance, clean UI
            design and exceptional user experiences.
          </p>

          <p>
            Focused on performance, clean UI design and exceptional user
            experiences.
          </p>
          <div class="flex flex-wrap items-center gap-4 pt-2">
            <a
              href="https://github.com/Fran-web-dev"
              class="flex h-12 w-12 items-center justify-center rounded-full bg-[#333333] transition-transform hover:scale-110"
            >
              <img src="/images/github.png" class="h-5 w-5 object-contain" />
            </a>

            <a
              href="mailto:franklinevillanueva4@gmail.com"
              class="flex h-12 w-12 items-center justify-center rounded-full bg-[#EA4335] transition-transform hover:scale-110"
            >
              <img
                src="/images/gmail.png"
                alt="Gmail"
                class="h-5 w-5 object-contain"
              />
            </a>
          </div>
          <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap">
            <a
              href="#contacto"
              class="inline-flex w-full items-center justify-center rounded-lg border border-transparent bg-[rgb(85,25,139)] px-7 py-3 text-sm font-semibold text-white transition-all duration-300 ease-out hover:-translate-y-1 hover:bg-white hover:text-[rgb(85,25,139)] hover:border-[rgb(85,25,139)] hover:shadow-xl sm:w-auto sm:px-9 sm:text-base"
            >
              CONTACT ME
            </a>
            <a
              href="/downloads/Franklin_Villanueva_Resume.pdf"
              download="Franklin_Villanueva_CV.pdf"
              class="inline-flex w-full items-center justify-center rounded-lg border border-transparent bg-[rgb(85,25,139)] px-7 py-3 text-sm font-semibold text-white transition-all duration-300 ease-out hover:-translate-y-1 hover:bg-white hover:text-[rgb(85,25,139)] hover:border-[rgb(85,25,139)] hover:shadow-xl sm:w-auto sm:px-9 sm:text-base"
            >
              DOWNLOAD MY RESUME
            </a>
          </div>
        </div>
      </div>
      <div class="relative order-1 lg:order-2">
        <div class="absolute inset-0 blur-[120px] opacity-20"></div>
        <div
          class="relative mx-auto max-w-xl overflow-hidden rounded-[24px] border border-white/10 shadow-[0_40px_120px_rgba(0,0,0,0.45)] sm:rounded-[32px]"
        >
          <img
            src="/images/profile.png"
            alt="Franklin working in a futuristic digital environment"
            class="aspect-[4/5] w-full object-cover sm:aspect-[4/4.5] lg:aspect-[4/5]"
            loading="lazy"
          />
          <div
            class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/90 via-black/40 to-transparent sm:p-6"
          >
            <p
              class="mb-2 text-[0.65rem] uppercase tracking-[0.35em] text-white/60 sm:text-sm sm:tracking-[0.5em]"
            >
              Presence
            </p>
            <p class="text-lg font-semibold text-white sm:text-2xl">
              Latam | Global Remote
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
