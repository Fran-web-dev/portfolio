---
import {
  SiAstro,
  SiCss,
  SiExpress,
  SiGit,
  SiMongodb,
  SiNextdotjs,
  SiNodedotjs,
  SiReact,
  SiTypescript,
} from "react-icons/si";

import IconWrapper from "./IconWrapper";

const skills = [
  { name: "React", color: "#61DAFB", icon: SiReact },
  { name: "MongoDB", color: "#47A248", icon: SiMongodb },
  { name: "Astro", color: "#FF5D01", icon: SiAstro },
  { name: "TypeScript", color: "#3178C6", icon: SiTypescript },
  { name: "Node.js", color: "#339933", icon: SiNodedotjs },
  { name: "Next.js", color: "#ffffff", icon: SiNextdotjs },
  { name: "CSS/SCSS", color: "#1572B6", icon: SiCss },
  { name: "Git", color: "#F05032", icon: SiGit },
  { name: "Express", color: "#ffffff", icon: SiExpress },
];

const highlights = [
  "Develop highly interactive Front End / User Interfaces for web and mobile applications",
  "Progressive Web Applications (PWA) in normal and SPA stacks",
  "Integration of third-party services such as Firebase, AWS and DigitalOcean",
];
---

<section
  id="tecnologias"
  class="scroll-mt-24 bg-[#171c28] px-8 py-24 font-Montserrat"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-16 lg:grid-cols-[0.95fr,1.05fr]">
      <div class="order-2 lg:order-1">
        <div class="relative mx-auto max-w-xl">
          <lottie-player
            src="/images/codingPerson.json"
            background="transparent"
            speed="1"
            loop
            autoplay
            class="block w-full aspect-[4/3]"
          ></lottie-player>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <h2
          class="mb-4 text-[clamp(3rem,5vw,4.8rem)] font-light leading-none text-white"
        >
          What I do
        </h2>

        <p
          class="mb-10 text-sm uppercase tracking-wide text-slate-300 md:text-base"
        >
          CRAZY FULL STACK DEVELOPER WHO WANTS TO EXPLORE EVERY TECH STACK
        </p>

        <div
          class="mb-12 grid grid-cols-[repeat(auto-fit,minmax(90px,1fr))] gap-x-6 gap-y-8"
        >
          {
            skills.map((skill) => (
              <div class="group flex flex-col items-center">
                <div
                  class="skill-icon text-5xl text-slate-400 transition-all duration-300 group-hover:scale-110"
                  style={`--skill-accent: ${skill.color};`}
                >
                  <IconWrapper Icon={skill.icon} />
                </div>
                <h3 class="mt-3 text-xs text-slate-500 transition-colors group-hover:text-slate-300">
                  {skill.name}
                </h3>
              </div>
            ))
          }
        </div>

        <div class="space-y-5">
          {
            highlights.map((item) => (
              <p class="flex gap-3 text-lg text-white">
                <span class="text-yellow-400">*</span>
                <span>{item}</span>
              </p>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script
  src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"
></script>

<style>
  .group:hover .skill-icon {
    color: var(--skill-accent);
  }

  @media (max-width: 768px) {
    #tecnologias {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    #tecnologias .grid {
      gap: 1.5rem;
    }
  }
</style>
