---
const projects = [
  {
    title: "React User List",
    description:
      "A user management web application built with React that allows users to view and manage user information through a clean and responsive interface.",
    technologies: ["React", "JavaScript", "CSS"],
    link: "https://github.com/Fran2007/react-users-list",
  },
  {
    title: "React Task Application",
    description:
      "A modern task management application that allows users to create, edit, delete, and organize tasks with a responsive and user-friendly interface.",
    technologies: ["React", "JavaScript", "Tailwindcss", "Jest"],
    link: "https://github.com/Fran2007/react-task-application",
  },
  {
    title: "ListOfBooks",
    description:
      "A web-based library application that allows users to browse and filter books by title and page count, as well as create and manage a personalized reading list.",
    technologies: ["React", "Tailwindcss"],
    link: "https://github.com/Fran2007/ListOfBooks",
  },
  {
    title: "ManagerLink",
    description:
      "A link management web application that allows users to save, edit, and delete links efficiently. Built with a modern frontend stack and focused on responsive design and usability.",
    technologies: [
      "React",
      "Tailwindcss",
      "MongoDB",
      "react-router-dom",
      "TypeScript",
    ],
    link: "https://github.com/Fran2007/manager-link",
  },
];
---

<section id="achievements" class="scroll-mt-24 py-24 px-8 bg-[#171c28]">
  <div class="max-w-7xl mx-auto">
    <h2
      class="text-[clamp(1rem,5vw,3.5rem)] font-Montserrat font-medium mb-8 bg-gradient-to-b text-white text-center leading-none"
    >
      Projects
    </h2>
    <div
      class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-8 max-w-6xl mx-auto"
    >
      {
        projects.map((project) => (
          <div class="bg-[#1b2233] shadow-xl rounded-xl p-8 transition-all duration-300 hover:border-slate-700 hover:shadow-slate-900 border border-slate-800">
            <div class="flex items-start justify-between mb-6">
              <h3 class="text-2xl font-semibold text-text mb-2">
                {project.title}
              </h3>
            </div>
            <p class="text-base font-Montserrat leading-relaxed text-slate-100 mb-6 flex-grow">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.technologies.map((tech) => (
                <span class="bg-accent/10 bg-[#1b2234] hover:bg-[#1b2244] px-3.5 py-1.5 rounded-md text-sm border border-accent/20">
                  {tech}
                </span>
              ))}
            </div>
            <a
              href={project.link}
              class="text-accent font-medium no-underline transition-all duration-300 inline-flex items-center gap-2 hover:text-accent-hover hover:gap-3"
            >
              View Project ->
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #proyectos .grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    #proyectos .bg-card-bg {
      padding: 1.5rem;
    }
  }
</style>
