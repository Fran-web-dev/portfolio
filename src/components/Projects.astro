---
const projects = [
  {
    title: "React User List",
    description:
      "A user management web application built with React that allows users to view and manage user information through a clean and responsive interface.",
    technologies: ["React", "JavaScript", "CSS"],
    link: "https://github.com/Fran2007/react-users-list",
  },
  {
    title: "React Task Application",
    description:
      "A modern task management application that allows users to create, edit, delete, and organize tasks with a responsive and user-friendly interface.",
    technologies: ["React", "JavaScript", "Tailwindcss", "Jest"],
    link: "https://github.com/Fran2007/react-task-application",
  },
  {
    title: "ListOfBooks",
    description:
      "A web-based library application that allows users to browse and filter books by title and page count, as well as create and manage a personalized reading list.",
    technologies: ["React", "Tailwindcss"],
    link: "https://github.com/Fran2007/ListOfBooks",
  },
  {
    title: "ManagerLink",
    description:
      "A link management web application that allows users to save, edit, and delete links efficiently. Built with a modern frontend stack and focused on responsive design and usability.",
    technologies: [
      "React",
      "Tailwindcss",
      "MongoDB",
      "react-router-dom",
      "TypeScript",
    ],
    link: "https://github.com/Fran2007/manager-link",
  },
];
---

<section id="achievements" class="scroll-mt-24 bg-[#171c28] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
  <div class="max-w-7xl mx-auto">
    <h2
      class="mb-8 text-[clamp(2rem,8vw,3.5rem)] font-Montserrat font-medium leading-none text-white text-center"
    >
      Projects
    </h2>
    <div
      class="mx-auto grid max-w-6xl grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-6 sm:gap-8"
    >
      {
        projects.map((project) => (
          <div class="rounded-xl border border-slate-800 bg-[#1b2233] p-6 shadow-xl transition-all duration-300 hover:border-slate-700 hover:shadow-slate-900 sm:p-8">
            <div class="mb-6 flex items-start justify-between gap-4">
              <h3 class="mb-2 text-xl font-semibold text-text sm:text-2xl">
                {project.title}
              </h3>
            </div>
            <p class="mb-6 text-sm font-Montserrat leading-relaxed text-slate-100 sm:text-base">
              {project.description}
            </p>
            <div class="mb-6 flex flex-wrap gap-2">
              {project.technologies.map((tech) => (
                <span class="rounded-md border border-accent/20 bg-[#1b2234] px-3 py-1.5 text-xs hover:bg-[#1b2244] sm:text-sm">
                  {tech}
                </span>
              ))}
            </div>
            <a
              href={project.link}
              class="inline-flex items-center gap-2 font-medium text-accent no-underline transition-all duration-300 hover:gap-3 hover:text-accent-hover"
            >
              View Project ->
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
